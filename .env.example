# Copy to .env.local for local overrides (already gitignored via *.local).
# On Vercel/Netlify, set these as environment variables in the dashboard instead.
VITE_API_BASE=https://localhost:7096/api

# PayPal Client ID is public by design (safe to expose client-side) — the Secret stays server-only, in the backend config.
VITE_PAYPAL_CLIENT_ID=your-paypal-sandbox-client-id
